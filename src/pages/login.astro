---
import "../styles/global.css";
import LoginForm from "../components/auth/LoginForm.tsx";
import Logo from "../components/auth/Logo.tsx";
import { ClientRouter } from "astro:transitions";
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Login - Programación Automática</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <ClientRouter />
    </head>
    <body
        class="h-screen flex overflow-hidden font-['Inter'] bg-[#f4f7f8] p-4 lg:p-6"
    >
        <div
            class="flex w-full h-full bg-white rounded-[32px] overflow-hidden shadow-[0px_20px_50px_rgba(0,0,0,0.1)]"
        >
            <!-- Lado Izquierdo - Branding con Imagen Solicitada -->
            <div
                class="hidden lg:flex flex-1 relative flex-col justify-center px-[8%] overflow-hidden text-white"
            >
                <!-- Imagen de fondo con overlay -->
                <div class="absolute inset-0 z-0">
                    <img
                        src="/DSC_0010.webp"
                        alt="Background"
                        class="w-full h-full object-cover"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"
                    >
                    </div>
                </div>

                <div
                    class="transition-transform duration-500 hover:scale-105 cursor-default z-10 w-fit"
                    transition:name="logo"
                >
                    <Logo className="mb-12" />
                </div>

                <div
                    class="max-w-[550px] z-10 animate-[float_8s_ease-in-out_infinite]"
                >
                    <div
                        class="text-6xl opacity-40 leading-none mb-4 font-serif"
                    >
                        “
                    </div>
                    <h2
                        class="text-4xl font-bold leading-[1.2] mb-8 tracking-tight animate-slide-up text-balance drop-shadow-lg"
                    >
                        Movilizamos a las personas de la zona oriental y
                        nororiental de Medellín, de manera cercana, segura y
                        confiable.
                    </h2>
                    <p
                        class="text-xl opacity-90 font-semibold flex items-center gap-4 animate-slide-up"
                        style="animation-delay: 0.3s;"
                    >
                        <span
                            class="w-12 h-[3px] bg-primary shadow-[0_0_10px_rgba(76,194,83,0.5)]"
                        ></span>
                        ¡Medellín Conduce el Cambio!
                    </p>
                </div>
            </div>

            <!-- Lado Derecho - Formulario con Preact -->
            <div
                class="flex-1 bg-white flex items-center justify-center p-4 lg:p-8 relative"
            >
                <div
                    class="w-full max-w-[420px] p-8 lg:p-10 bg-white rounded-[28px] animate-fade-in"
                >
                    <div class="mb-12">
                        <p
                            class="text-primary font-bold uppercase tracking-[0.2em] text-[10px] mb-2 animate-slide-up"
                            style="animation-delay: 0.05s;"
                        >
                            Programación Automática de Mantenimiento
                        </p>
                        <h1
                            class="text-4xl font-bold text-texto-dark mb-3 tracking-tight animate-slide-up"
                            style="animation-delay: 0.15s;"
                        >
                            Bienvenido
                        </h1>
                        <p
                            class="text-texto-grey font-medium animate-slide-up"
                            style="animation-delay: 0.2s;"
                        >
                            Ingresa para gestionar tu código
                        </p>
                    </div>

                    <LoginForm client:load />

                    <div
                        class="mt-14 text-center text-sm text-texto-grey font-medium flex flex-col items-center gap-2"
                    >
                        <div class="opacity-60 text-xs">
                            &copy; 2026 SAO6 - Sistema Alimentador Oriental
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <style>
            @keyframes slide-up {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            .animate-slide-up {
                animation: slide-up 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
            }
            @keyframes fade-in {
                from {
                    opacity: 0;
                    transform: scale(0.98);
                }
                to {
                    opacity: 1;
                    transform: scale(1);
                }
            }
            .animate-fade-in {
                animation: fade-in 0.8s ease-out;
            }
        </style>
    </body>
</html>
