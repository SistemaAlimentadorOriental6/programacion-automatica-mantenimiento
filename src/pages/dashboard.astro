---
import "../styles/global.css";
import DashboardActions from "../components/dashboard/DashboardActions.tsx";
import DashboardGrid from "../components/dashboard/DashboardGrid.tsx";
import UserMenu from "../components/dashboard/UserMenu.tsx";
import { ClientRouter } from "astro:transitions";
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Dashboard - SAO6</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <ClientRouter />
    </head>
    <body class="min-h-screen bg-[#f4f7f8] font-['Inter'] flex flex-col">
        <!-- Header Premium -->
        <header
            class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 shadow-sm"
        >
            <div class="max-w-[1850px] mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center h-20">
                    <div class="flex items-center gap-4" transition:name="logo">
                        <div
                            class="bg-primary p-2 rounded-xl shadow-lg shadow-primary/20"
                        >
                            <img
                                src="/favicon.ico"
                                alt="Logo"
                                class="w-8 h-8 object-contain brightness-0 invert"
                            />
                        </div>
                        <div class="flex flex-col">
                            <span
                                class="text-xl font-bold text-texto-dark leading-tight"
                                >SAO6</span
                            >
                            <span
                                class="text-xs font-semibold text-primary uppercase tracking-widest"
                                >Programación Automática</span
                            >
                        </div>
                    </div>

                    <div class="flex items-center gap-4">
                        <UserMenu client:only="preact" />
                    </div>
                </div>
            </div>
        </header>

        <main
            class="max-w-[1850px] mx-auto px-4 sm:px-6 lg:px-8 py-10 flex-1 w-full"
        >
            <div class="animate-fade-in">
                <div
                    class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6"
                >
                    <div>
                        <h1
                            class="text-4xl font-extrabold text-texto-dark tracking-tight"
                        >
                            Panel de Control
                        </h1>
                    </div>

                    <!-- Acciones Globales Interactivas -->
                    <DashboardActions client:only="preact" />
                </div>

                <!-- Grid Dinámico con Funcionalidad de Ampliar -->
                <DashboardGrid client:only="preact" />
            </div>
        </main>

        <footer
            class="max-w-[1850px] mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-gray-100 mt-auto w-full"
        >
            <div
                class="flex flex-col md:flex-row justify-center items-center gap-4 text-texto-grey font-medium text-sm"
            >
                <div class="flex items-center gap-1">
                    Desarrollado por el área de mejora continua
                    <span class="text-red-500 animate-pulse ml-1">❤️</span>
                </div>
            </div>
        </footer>

        <style is:global>
            @keyframes fade-in {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            .animate-fade-in {
                animation: fade-in 0.8s ease-out;
            }

            /* Scrollbar Personalizado Premium */
            ::-webkit-scrollbar {
                width: 8px;
                height: 8px;
            }
            ::-webkit-scrollbar-track {
                background: #f1f5f9;
                border-radius: 10px;
            }
            ::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
                border: 2px solid #f1f5f9;
                transition: all 0.3s ease;
            }
            ::-webkit-scrollbar-thumb:hover {
                background: #4cc253;
                border: 1px solid #f1f5f9;
            }

            /* Para Firefox */
            * {
                scrollbar-width: thin;
                scrollbar-color: #cbd5e1 #f1f5f9;
            }
        </style>
    </body>
</html>
